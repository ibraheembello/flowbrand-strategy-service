# ─────────────────────────────────────────────────────────────────────
#  FlowBrand Strategy Service — environment template
#
#  Copy this file to `.env` and fill in real values.
#  Never commit `.env` (it's in .gitignore).
# ─────────────────────────────────────────────────────────────────────

# ── Runtime ──
NODE_ENV=development
PORT=3009

# ── Database (PostgreSQL) ──
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=flowbrand
DB_PASSWORD=
DB_NAME=flowbrand_strategy
DB_SSL=false
DB_ENTITIES=dist/src/modules/**/entities/**/*.entity{.ts,.js}
DB_MIGRATIONS=dist/**/migrations/*{.ts,.js}

# ── JWT (validates tokens issued by the main FlowBrand backend) ──
# Must match the JWT_SECRET on the FlowBrand main service.
JWT_SECRET=
JWT_EXPIRY_TIMEFRAME=3600

# ── Anthropic Claude ──
# Get a key from https://console.anthropic.com
ANTHROPIC_API_KEY=
# Model ID. claude-sonnet-4-6 = strong default. claude-haiku-4-5 = cheaper.
ANTHROPIC_MODEL=claude-sonnet-4-6
# Hard ceiling on per-request tokens (cost guard).
ANTHROPIC_MAX_OUTPUT_TOKENS=4096
# Request timeout in ms. Past this, fail with 504 to the client.
ANTHROPIC_TIMEOUT_MS=30000

# ── Strategy generation limits ──
# Successful generations per user per UTC day.
STRATEGY_DAILY_LIMIT=5

# ── Curveball fallback (see RFC change log) ──
# When true, /strategies/generate returns a canned strategy if Claude fails.
# Default off in production; flip on if you need the demo to work without LLM.
STRATEGY_FALLBACK_ENABLED=false
